Options -Indexes

# ---------------------------------------------------------------------------
# PTMD rewrite rules
# ---------------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Admin: allow clean extension-less paths like /admin/cases to resolve to
    # /admin/cases.php when that file exists.  Real files and directories are
    # left alone so existing /admin/*.php links keep working.
    RewriteCond %{REQUEST_URI} ^/admin/([a-z0-9_-]+)$ [NC]
    RewriteCond %{DOCUMENT_ROOT}/admin/%1.php -f
    RewriteRule ^admin/([a-z0-9_-]+)$ /admin/$1.php [L]

    # Public front controller: everything that isn't a real file/dir goes
    # through index.php.  QSA preserves any existing query string (so legacy
    # /index.php?page=cases links still work), L stops further rewrites.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# Block direct access to sensitive PHP includes
<FilesMatch "^(bootstrap|config|db|functions)\.(php)$">
    Require all denied
</FilesMatch>

# Disable PHP error display in production
php_flag display_errors Off
php_flag log_errors On

# Security headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
